# Copy this file to deploy/env and adjust values for your machine or server.
# Do not commit real production passwords in deploy/env.

# Nginx
NGINX_IMAGE=nginx:1.27-alpine
NGINX_HTTP_PORT=80
NGINX_SERVER_NAME=_

# MySQL
MYSQL_PORT=13306
MYSQL_ROOT_PASSWORD=root
DB_NAME=lzf_studio
DB_USERNAME=root
DB_PASSWORD=root

# Backend
BACKEND_IMAGE=lzf-studio-backend:latest
BACKEND_PORT=9090

# Frontend service image.
FRONTEND_IMAGE=lzf-studio-frontend:latest
FRONTEND_PORT=8080

# Apps proxied by the Dockerized Nginx gateway.
# These defaults point from the Nginx container back to services running on the host machine.
APP_CHAT_UPSTREAM=http://host.docker.internal:3001
APP_ADMIN_UPSTREAM=http://host.docker.internal:8082
APP_AI_UPSTREAM=http://host.docker.internal:5173
